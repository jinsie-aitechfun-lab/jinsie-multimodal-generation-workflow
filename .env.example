# =========================
# HTTP / CORS
# =========================

# Comma-separated browser origins allowed to call the FastAPI backend.
# Production example: CORS_ALLOW_ORIGINS=https://studio.jinsie.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://studio.jinsie.com

# =========================
# Story / LLM
# =========================

# Story generation uses an OpenAI-compatible chat endpoint.
STORY_PROVIDER=openai_compatible
STORY_MODEL=
STORY_TIMEOUT_SECONDS=120

# OpenAI-compatible endpoint aliases used by story / vision / fallback providers.
OPENAI_BASE_URL=https://your-openai-compatible-base-url/v1
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
CHARACTER_PROFILE_PROVIDER=

# =========================
# TTS
# =========================

# Real TTS switch
TTS_ENABLED=false

# If true, when real TTS fails it falls back to placeholder manifest mode.
# If false, workflow run will fail directly.
TTS_FALLBACK_TO_MOCK=true

# Generic OpenAI-compatible TTS provider
TTS_PROVIDER=openai_compatible_tts
TTS_API_BASE_URL=https://your-openai-compatible-base-url/v1
TTS_API_KEY=
TTS_MODEL=your-tts-model
TTS_VOICE=default
TTS_TIMEOUT_SECONDS=120

# Optional speaker-specific overrides
TTS_VOICE_NARRATOR=
TTS_VOICE_MOTHER=
TTS_VOICE_CHILD=

# =========================
# Image Provider
# =========================

# Primary image provider:
# - pillow_storybook_renderer
# - api_image_generator
IMAGE_PROVIDER=pillow_storybook_renderer

# Fallback provider when primary provider fails
IMAGE_FALLBACK_PROVIDER=pillow_storybook_renderer

# Strategy when API provider hits 429/rate-limit:
# - pending
# - fail
IMAGE_429_STRATEGY=pending

# If true, allow api_image_generator to fall back to pillow_storybook_renderer
API_IMAGE_FALLBACK_TO_PILLOW=true

# Enable real API image generation
API_IMAGE_ENABLED=false

# OpenAI-compatible / SiliconFlow style image endpoint
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Model config
SILICONFLOW_IMAGE_MODEL=Kwai-Kolors/Kolors
SILICONFLOW_IMAGE_SIZE=1280x720
SILICONFLOW_IMAGE_NEGATIVE_PROMPT=low quality, blurry, distorted anatomy, broken composition, extra limbs, duplicated subject, unreadable details
SILICONFLOW_IMAGE_STEPS=20
SILICONFLOW_IMAGE_GUIDANCE=7.5
SILICONFLOW_IMG2IMG_ENABLED=false
SILICONFLOW_IMG2IMG_STRENGTH=0.75
KLING_IMAGE_FALLBACK_TO_PILLOW=false
IMAGE_QUALITY_MAX_RETRIES=0

# Optional visual reviewer for image candidate auto-selection.
# Without this, the selector can only use metadata / color / contrast signals.
IMAGE_REVIEW_VISION_ENABLED=false
IMAGE_REVIEW_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
OPENAI_VISION_MODEL=
VISION_MODEL=
IMAGE_REVIEW_VISION_API_KEY=
IMAGE_REVIEW_VISION_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_REVIEW_VISION_TIMEOUT_SECONDS=60

# Test switches
FORCE_IMAGE_RATE_LIMIT=false
